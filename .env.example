# --- Vercel (web) ---
# URL pública del servicio analyzer (Render). Sin barra final.
# PUBLIC_ANALYZE_API_URL=https://theme-inspector-analyzer.onrender.com

# --- Servicio analyzer (Render) — obligatorio en producción ---
PLAYWRIGHT_ENABLED=true
PORT=3001
NODE_ENV=production

# CORS: dominios de tu app (separados por coma). Usa comodín para previews:
# ALLOWED_ORIGINS=https://tu-app.vercel.app,https://*.vercel.app

# Opcional: clave para llamadas API sin navegador (NO la pongas en PUBLIC_*)
# ANALYZER_API_KEY=genera-un-secreto-largo-aleatorio

# --- Solo desarrollo local (pnpm dev) ---
# Playwright va activo por defecto. Primera vez: pnpm playwright:install
# Desactivar navegador (solo fetch; sitios 403 fallarán): ENABLE_PLAYWRIGHT=false
