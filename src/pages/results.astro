---
import StudyLayout from "../layouts/StudyLayout.astro";
import Showcase from "../components/Showcase.astro";
---

<StudyLayout title="Theme Inspector â€” Estudio CSS">
  <header class="studyTop no-print">
    <a class="back" href="/">â† Nueva URL</a>
    <div class="meta">
      <h1>Estudio de diseÃ±o</h1>
      <p id="study-url" class="url">Cargando anÃ¡lisisâ€¦</p>
    </div>
  </header>

  <main class="studyMain">
    <div id="study-loading" class="loading" aria-live="polite">
      <div class="spinner" aria-hidden="true"></div>
      <p>Extrayendo variables y patrones del sitioâ€¦</p>
    </div>

    <div id="study-error" class="error hidden" role="alert"></div>

    <div id="study-content" class="content hidden">
      <section class="statsSection" aria-labelledby="stats-title">
        <h2 id="stats-title">Resumen del CSS</h2>
        <div id="stats-grid" class="statsGrid"></div>
      </section>

      <Showcase hidden={false} />

      <p id="identity-note" class="identityNote hidden" role="status"></p>

      <section class="brandSection tokensDeclared" aria-labelledby="brand-tokens-title">
        <div class="brandHead">
          <h2 id="brand-tokens-title">Tokens de marca (design system)</h2>
          <p>
            Valores declarados en CSS como marca. Los roles (primario/secundario) se asignan segÃºn lo
            que prevalece en pantalla; un token semÃ¡ntico (p. ej. brand-red) se lista aquÃ­ aunque no
            sea el color dominante de la UI.
          </p>
        </div>
        <div id="brand-tokens-grid" class="brandGrid"></div>
      </section>

      <section class="brandSection" aria-labelledby="brand-visible-title">
        <div class="brandHead">
          <h2 id="brand-visible-title">Marca visible en pantalla</h2>
          <p>Colores que realmente aparecen en la UI analizada (viewport). Prioridad para primario y secundario.</p>
        </div>
        <div id="brand-visible-grid" class="brandGrid"></div>
      </section>

      <section class="brandSection legacy" aria-labelledby="brand-legacy-title">
        <div class="brandHead">
          <h2 id="brand-legacy-title">Paleta legacy del CSS</h2>
          <p>Tokens definidos en hojas de estilo pero poco o nada visibles en esta vista.</p>
        </div>
        <div id="brand-legacy-grid" class="brandGrid"></div>
      </section>

      <section class="tokensSection" aria-labelledby="tokens-title">
        <div class="tokensHead">
          <h2 id="tokens-title">Variables del sitio</h2>
          <label class="search">
            <span class="sr-only">Buscar variable</span>
            <input id="var-search" type="search" placeholder="Buscar por nombre o valorâ€¦" />
          </label>
        </div>
        <div id="category-sections" class="categorySections"></div>
      </section>
    </div>
  </main>

  <style lang="scss">
    /* Fondo de la app (independiente de --extracted-bg del showcase) */
    :global(body) {
      background: #070a12;
    }

    .studyTop {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 20px 12px;
      display: grid;
      gap: 10px;

      .back {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.72);
        width: fit-content;
        transition: color 140ms ease;

        &:hover {
          color: rgba(255, 255, 255, 0.95);
        }
      }

      h1 {
        margin: 0;
        font-size: clamp(24px, 2.2vw, 36px);
        letter-spacing: -0.02em;
      }

      .url {
        margin: 4px 0 0;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.62);
        word-break: break-all;
      }
    }

    .studyMain {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 20px 64px;
      display: grid;
      gap: 22px;
    }

    .hidden {
      display: none !important;
    }

    .loading {
      display: grid;
      justify-items: center;
      gap: 12px;
      padding: 48px 20px;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.03);

      p {
        margin: 0;
        color: rgba(255, 255, 255, 0.72);
        font-size: 14px;
      }

      .spinner {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.18);
        border-top-color: rgba(255, 255, 255, 0.85);
        animation: spin 0.8s linear infinite;
      }
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .error {
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid rgba(248, 113, 113, 0.35);
      background: rgba(248, 113, 113, 0.12);
      color: rgba(255, 255, 255, 0.9);
      font-size: 14px;
    }

    .identityNote {
      max-width: 1180px;
      margin: 0 auto 16px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.04);
      color: rgba(255, 255, 255, 0.78);
      font-size: 13px;
      line-height: 1.45;
    }

    .content {
      display: grid;
      gap: 22px;
    }

    .statsSection {
      h2 {
        margin: 0 0 12px;
        font-size: 16px;
        letter-spacing: -0.01em;
      }
    }

    .statsGrid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;

      :global(.statCard) {
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: transform 160ms ease, border-color 160ms ease;

        &:hover {
          transform: translateY(-1px);
          border-color: rgba(255, 255, 255, 0.16);
        }

        :global(.value) {
          display: block;
          font-size: 26px;
          font-weight: 300;
          letter-spacing: -0.02em;
          color: rgba(255, 255, 255, 0.95);
        }

        :global(.label) {
          display: block;
          margin-top: 4px;
          font-size: 11px;
          text-transform: uppercase;
          letter-spacing: 0.07em;
          color: rgba(255, 255, 255, 0.58);
        }
      }
    }

    .brandSection {
      border-radius: 18px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.1);

      &.legacy {
        border-style: dashed;
        background: rgba(0, 0, 0, 0.14);
      }

      .brandHead {
        margin-bottom: 12px;

        h2 {
          margin: 0 0 4px;
          font-size: 16px;
          letter-spacing: -0.01em;
        }

        p {
          margin: 0;
          font-size: 13px;
          color: rgba(255, 255, 255, 0.62);
        }
      }

      .brandGrid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(172px, 1fr));
        gap: 12px;
      }

      :global(.brandCard) {
        --card-color: #888;
        position: relative;
        display: grid;
        grid-template-rows: auto 1fr;
        overflow: hidden;
        padding: 0;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(8, 12, 22, 0.72);
        cursor: pointer;
        text-align: left;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease;

        &:hover {
          transform: translateY(-2px);
          border-color: rgba(255, 255, 255, 0.2);
          box-shadow: 0 14px 32px rgba(0, 0, 0, 0.32);

          :global(.copyHint) {
            opacity: 1;
          }
        }

        &:focus-visible {
          outline: 2px solid rgba(56, 189, 248, 0.65);
          outline-offset: 2px;
        }

        :global(.chipArea) {
          position: relative;
          height: 56px;
          background: var(--card-color);
        }

        :global(.chip) {
          display: block;
          width: 100%;
          height: 100%;
          background: var(--card-color);
        }

        :global(.roleBadge) {
          position: absolute;
          top: 8px;
          left: 8px;
          padding: 3px 8px;
          border-radius: 999px;
          font-size: 10px;
          font-weight: 700;
          letter-spacing: 0.04em;
          text-transform: uppercase;
          color: rgba(255, 255, 255, 0.95);
          background: rgba(0, 0, 0, 0.42);
          border: 1px solid rgba(255, 255, 255, 0.2);
          backdrop-filter: blur(6px);
        }

        :global(.cardInfo) {
          display: grid;
          gap: 4px;
          padding: 10px 12px 12px;
        }

        :global(.hex) {
          font-family: ui-monospace, "Cascadia Code", "SF Mono", Consolas, monospace;
          font-size: 13px;
          font-weight: 700;
          letter-spacing: 0.02em;
          color: rgba(255, 255, 255, 0.96);
        }

        :global(.meta) {
          font-size: 11px;
          line-height: 1.4;
          color: rgba(255, 255, 255, 0.58);
        }

        :global(.copyHint) {
          position: absolute;
          right: 8px;
          bottom: 8px;
          padding: 2px 7px;
          border-radius: 6px;
          font-size: 9px;
          font-weight: 600;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          color: rgba(255, 255, 255, 0.75);
          background: rgba(0, 0, 0, 0.35);
          opacity: 0;
          transition: opacity 140ms ease;
        }

      }

      :global(.brandCard.isRole) {
        border-color: rgba(56, 189, 248, 0.4);
        box-shadow:
          0 8px 24px rgba(0, 0, 0, 0.22),
          0 0 0 1px rgba(56, 189, 248, 0.12);
      }

      :global(.brandCard.isPrimary) {
        border-color: rgba(255, 204, 0, 0.45);

        :global(.roleBadge) {
          background: rgba(255, 204, 0, 0.22);
          border-color: rgba(255, 204, 0, 0.45);
        }
      }

      :global(.brandCard.isToken) {
        :global(.tokenName) {
          font-size: 11px;
          font-weight: 600;
          color: rgba(167, 139, 250, 0.95);
          word-break: break-all;
        }
      }
    }

    .tokensSection {
      .tokensHead {
        display: flex;
        flex-wrap: wrap;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;

        h2 {
          margin: 0;
          font-size: 16px;
        }
      }

      .search input {
        width: min(320px, 100%);
        height: 40px;
        padding: 0 12px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(0, 0, 0, 0.22);
        color: rgba(255, 255, 255, 0.92);
        outline: none;

        &:focus {
          border-color: rgba(56, 189, 248, 0.55);
          box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
        }
      }
    }

    .categorySections {
      display: grid;
      gap: 18px;
    }

    .categorySections :global(.categoryBlock) {
      border-radius: 18px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.1);

      :global(.categoryHead) {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;

        h3 {
          margin: 0;
          font-size: 14px;
          letter-spacing: 0.05em;
          text-transform: uppercase;
          color: rgba(255, 255, 255, 0.78);
        }

        :global(.count) {
          font-size: 12px;
          color: rgba(255, 255, 255, 0.5);
        }
      }

      :global(.varGrid) {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 10px;
      }

      :global(.varCard) {
        --swatch-color: transparent;
        display: grid;
        grid-template-columns: 52px 1fr;
        gap: 12px;
        align-items: stretch;
        padding: 10px 12px 10px 10px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(8, 12, 22, 0.55);
        cursor: pointer;
        text-align: left;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background-color 160ms ease,
          box-shadow 160ms ease;

        &:hover {
          transform: translateY(-1px);
          border-color: rgba(255, 255, 255, 0.18);
          background: rgba(8, 12, 22, 0.82);
          box-shadow: 0 10px 28px rgba(0, 0, 0, 0.24);
        }

        &:focus-visible {
          outline: 2px solid rgba(56, 189, 248, 0.55);
          outline-offset: 2px;
        }

        :global(.swatch) {
          width: 52px;
          min-height: 52px;
          align-self: stretch;
          border-radius: 12px;
          border: 1px solid rgba(255, 255, 255, 0.14);
          background: var(--swatch-color, rgba(255, 255, 255, 0.06));
        }

        :global(.swatch.isToken) {
          background: rgba(255, 255, 255, 0.08);
        }

        :global(.varBody) {
          min-width: 0;
          display: grid;
          gap: 4px;
          align-content: center;
        }

        :global(.name) {
          font-family: ui-monospace, "Cascadia Code", "SF Mono", Consolas, monospace;
          font-size: 12px;
          font-weight: 700;
          color: rgba(255, 255, 255, 0.94);
          word-break: break-all;
        }

        :global(.value) {
          font-size: 11px;
          line-height: 1.35;
          color: rgba(255, 255, 255, 0.68);
          word-break: break-all;
        }

        :global(.usage) {
          font-size: 10px;
          color: rgba(255, 255, 255, 0.45);
        }

      }

    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    @media (max-width: 900px) {
      .statsGrid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 520px) {
      .statsGrid {
        grid-template-columns: 1fr;
      }
    }

    @media print {
      :global(body) {
        background: #fff !important;
        color: #111 !important;
      }

      .studyTop .back,
      .tokensSection .search {
        display: none !important;
      }
    }
  </style>

  <script>
    import { initResultsPage } from "../scripts/resultsApp";
    initResultsPage();
  </script>
</StudyLayout>
