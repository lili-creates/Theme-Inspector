---
type Props = {
  hidden?: boolean;
};

const { hidden = true } = Astro.props;
---

<section
  id="theme-showcase"
  class:list={["showcase", hidden && "hidden"]}
  aria-live="polite"
>
  <header class="showcaseHeader">
    <div class="titleRow">
      <div>
        <h2>Resultado</h2>
        <p>Haz clic en cualquier color para copiarlo.</p>
      </div>
      <button class="printBtn no-print" type="button" data-print>Descargar Reporte PDF</button>
    </div>
  </header>

  <div class="grid">
    <section class="panel palette" aria-labelledby="palette-title">
      <h3 id="palette-title">Paleta de Color</h3>
      <div class="paletteGrid">
        <button class="swatch" type="button" data-copy="var(--extracted-primary)">
          <span class="chip" style="background: var(--extracted-primary, #999)"></span>
          <span class="meta">
            <span class="label">Primary</span>
            <span class="value" data-value="--extracted-primary">var(--extracted-primary)</span>
          </span>
        </button>

        <button class="swatch" type="button" data-copy="var(--extracted-secondary)">
          <span class="chip" style="background: var(--extracted-secondary, #777)"></span>
          <span class="meta">
            <span class="label">Secondary</span>
            <span class="value" data-value="--extracted-secondary">var(--extracted-secondary)</span>
          </span>
        </button>

        <button class="swatch" type="button" data-copy="var(--extracted-bg)">
          <span class="chip" style="background: var(--extracted-bg, #111)"></span>
          <span class="meta">
            <span class="label">Background</span>
            <span class="value" data-value="--extracted-bg">var(--extracted-bg)</span>
          </span>
        </button>

        <button class="swatch" type="button" data-copy="var(--extracted-text-surface)">
          <span class="chip" style="background: var(--extracted-text-surface, #eee)"></span>
          <span class="meta">
            <span class="label">Texto (fondo)</span>
            <span class="value" data-value="--extracted-text-surface">var(--extracted-text-surface)</span>
          </span>
        </button>

        <button class="swatch" type="button" data-copy="var(--extracted-text-button)">
          <span class="chip" style="background: var(--extracted-text-button, #fff)"></span>
          <span class="meta">
            <span class="label">Texto (botón)</span>
            <span class="value" data-value="--extracted-text-button">var(--extracted-text-button)</span>
          </span>
        </button>
      </div>
      <div class="paletteRankedWrap">
        <h4>Marca visible (ordenada por prevalencia en pantalla)</h4>
        <div id="palette-ranked" class="paletteRanked" aria-label="Colores detectados en el CSS"></div>
      </div>
      <div class="toast" role="status" aria-live="polite"></div>
    </section>

    <section class="panel preview" aria-labelledby="preview-title">
      <div class="previewHead">
        <div>
          <h3 id="preview-title">Vista previa del sitio</h3>
          <p class="previewNote">
            Captura y, si el sitio lo permite, vista en vivo de la URL analizada.
          </p>
        </div>
        <div class="previewActions no-print">
          <button type="button" id="preview-live-toggle" class="previewToggle hidden">
            Vista en vivo
          </button>
          <a
            id="preview-open-tab"
            class="openTab hidden"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
          >Abrir sitio</a>
        </div>
      </div>

      <div class="previewFrame">
        <div class="previewChrome" aria-hidden="true">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span id="preview-site-host" class="chromeTitle">—</span>
        </div>

        <div class="sitePreview">
          <p id="site-preview-loading" class="siteLoading hidden" aria-live="polite">
            Generando captura del sitio…
          </p>
          <img
            id="site-preview-shot"
            class="siteShot hidden"
            alt="Captura del sitio analizado"
            loading="lazy"
          />
          <iframe
            id="site-preview-frame"
            class="siteFrame hidden"
            title="Vista en vivo del sitio analizado"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <p id="site-preview-empty" class="siteEmpty">Analiza una URL para ver la vista previa.</p>
        </div>
        <p id="site-preview-note" class="siteNote hidden" role="status">
          Muchos sitios bloquean el iframe (X-Frame-Options). La captura del análisis es la referencia fiable.
        </p>
      </div>
    </section>
  </div>
</section>

<script is:inline>
  const root = document.getElementById("theme-showcase");
  if (root) {
    const toast = root.querySelector(".toast");

    const showToast = (text) => {
      if (!toast) return;
      toast.textContent = text;
      toast.classList.add("isVisible");
      window.clearTimeout(showToast._t);
      showToast._t = window.setTimeout(() => toast.classList.remove("isVisible"), 1200);
    };

    root.addEventListener("click", async (e) => {
      const printBtn = e.target?.closest?.("[data-print]");
      if (printBtn) {
        window.print();
        return;
      }

      const btn = e.target?.closest?.("[data-copy]");
      if (!btn) return;
      const valueNode = btn.querySelector?.("[data-value]");
      const displayed = valueNode?.textContent?.trim() || "";
      const varName = valueNode?.getAttribute?.("data-value");
      const resolved =
        displayed.startsWith("#") || displayed.startsWith("rgb")
          ? displayed
          : varName
            ? getComputedStyle(root).getPropertyValue(varName).trim()
            : "";
      const token = btn.getAttribute("data-copy") || "";
      const toCopy = resolved || token;
      try {
        await navigator.clipboard.writeText(toCopy);
        showToast(`Copiado: ${toCopy}`);
      } catch {
        showToast("No se pudo copiar");
      }
    });
  }
</script>

<style lang="scss">
  .hidden {
    display: none;
  }

  .showcase {
    // Fallbacks locales; el style inline del análisis sobrescribe cada variable
    --extracted-primary: var(--extracted-primary, #ffd200);
    --extracted-secondary: var(--extracted-secondary, #38bdf8);
    --extracted-bg: var(--extracted-bg, #0b1020);
    --extracted-text-surface: var(--extracted-text-surface, rgba(255, 255, 255, 0.92));
    --extracted-text-button: var(--extracted-text-button, #ffffff);
    --extracted-text: var(--extracted-text-surface);

    isolation: isolate;
    border-radius: 18px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);

    // smooth transitions when variables change between analyses
    transition: opacity 220ms ease;

    .showcaseHeader {
      display: grid;
      gap: 4px;
      margin-bottom: 14px;

      .titleRow {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: start;
      }

      h2 {
        margin: 0;
        font-size: 16px;
        letter-spacing: -0.01em;
      }

      p {
        margin: 0;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.70);
      }

      .printBtn {
        height: 38px;
        padding: 0 12px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.92);
        cursor: pointer;
        transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease,
          opacity 160ms ease;

        &:hover {
          transform: translateY(-1px);
          background: rgba(255, 255, 255, 0.10);
          border-color: rgba(255, 255, 255, 0.22);
        }

        &:active {
          transform: translateY(0);
          opacity: 0.92;
        }
      }
    }

    .grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 14px;
      align-items: start;
    }

    .panel {
      border-radius: 16px;
      padding: 14px;
      background: rgba(0, 0, 0, 0.18);
      border: 1px solid rgba(255, 255, 255, 0.10);

      h3 {
        margin: 0 0 12px;
        font-size: 13px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.70);
      }
    }

    .palette {
      position: relative;

      .paletteGrid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }

      .swatch {
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 12px;
        align-items: center;
        width: 100%;
        text-align: left;
        padding: 12px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: rgba(255, 255, 255, 0.02);
        cursor: pointer;
        transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease,
          opacity 160ms ease;

        &:hover {
          transform: translateY(-1px);
          background: rgba(255, 255, 255, 0.03);
          border-color: rgba(255, 255, 255, 0.14);
        }

        &:active {
          transform: translateY(0);
          opacity: 0.92;
        }

        .chip {
          width: 44px;
          height: 44px;
          border-radius: 12px;
          border: 1px solid rgba(255, 255, 255, 0.12);
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
          transition: background-color 280ms ease, border-color 280ms ease;
        }

        .meta {
          display: grid;
          gap: 4px;
          min-width: 0;
        }

        .label {
          font-size: 12px;
          font-weight: 700;
          color: rgba(255, 255, 255, 0.88);
        }

        .value {
          font-size: 12px;
          color: rgba(255, 255, 255, 0.62);
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
      }

      .paletteRankedWrap {
        margin-top: 14px;

        h4 {
          margin: 0 0 10px;
          font-size: 12px;
          font-weight: 600;
          color: rgba(255, 255, 255, 0.72);
        }
      }

      .paletteRanked {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(128px, 1fr));
        gap: 10px;

        :global(.rankSwatch) {
          --card-color: #888;
          display: grid;
          grid-template-rows: auto 1fr;
          overflow: hidden;
          padding: 0;
          border-radius: 14px;
          border: 1px solid rgba(255, 255, 255, 0.1);
          background: rgba(8, 12, 22, 0.65);
          cursor: pointer;
          text-align: left;
          box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2);
          transition:
            transform 160ms ease,
            border-color 160ms ease,
            box-shadow 160ms ease;

          &:hover {
            transform: translateY(-2px);
            border-color: rgba(255, 255, 255, 0.18);
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
          }

          :global(.chipArea) {
            position: relative;
            height: 44px;
            background: var(--card-color);
          }

          :global(.chip) {
            display: block;
            width: 100%;
            height: 100%;
            background: var(--card-color);
          }

          :global(.roleBadge) {
            position: absolute;
            top: 6px;
            left: 6px;
            padding: 2px 6px;
            border-radius: 999px;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.95);
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.18);
          }

          :global(.cardInfo) {
            display: grid;
            gap: 3px;
            padding: 8px 9px 9px;
          }

          :global(.hex) {
            font-family: ui-monospace, "Cascadia Code", "SF Mono", Consolas, monospace;
            font-size: 11px;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.92);
          }

          :global(.meta) {
            font-size: 10px;
            line-height: 1.35;
            color: rgba(255, 255, 255, 0.55);
          }

          &:global(.isPrimary) {
            border-color: rgba(255, 204, 0, 0.45);
          }
        }
      }

      .toast {
        position: absolute;
        left: 14px;
        bottom: 14px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(0, 0, 0, 0.35);
        color: rgba(255, 255, 255, 0.86);
        font-size: 12px;
        opacity: 0;
        transform: translateY(6px);
        pointer-events: none;
        transition: opacity 160ms ease, transform 160ms ease;

        &.isVisible {
          opacity: 1;
          transform: translateY(0);
        }
      }
    }

    .preview {
      display: flex;
      flex-direction: column;
      min-height: 0;

      .previewHead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;

        h3 {
          margin: 0 0 4px;
        }

        .previewNote {
          margin: 0;
          font-size: 12px;
          line-height: 1.4;
          color: rgba(255, 255, 255, 0.55);
          text-transform: none;
          letter-spacing: normal;
        }

        .previewActions {
          display: flex;
          flex-shrink: 0;
          gap: 8px;
        }

        .previewToggle,
        .openTab {
          height: 32px;
          padding: 0 12px;
          border-radius: 8px;
          border: 1px solid rgba(255, 255, 255, 0.14);
          background: rgba(255, 255, 255, 0.06);
          color: rgba(255, 255, 255, 0.9);
          font-size: 12px;
          font-weight: 600;
          cursor: pointer;
          transition: background-color 160ms ease, border-color 160ms ease;
        }

        .openTab {
          display: inline-flex;
          align-items: center;
          text-decoration: none;
        }

        .previewToggle:hover,
        .openTab:hover {
          background: rgba(255, 255, 255, 0.1);
          border-color: rgba(255, 255, 255, 0.22);
        }

        .previewToggle.isActive {
          border-color: rgba(56, 189, 248, 0.45);
          background: rgba(56, 189, 248, 0.12);
        }
      }

      .previewFrame {
        flex: 1;
        display: flex;
        flex-direction: column;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
        transition: border-color 320ms ease, box-shadow 320ms ease;
      }

      .previewChrome {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background: rgba(0, 0, 0, 0.35);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);

        .dot {
          width: 8px;
          height: 8px;
          border-radius: 50%;
          background: rgba(255, 255, 255, 0.22);

          &:first-child {
            background: #f87171;
          }

          &:nth-child(2) {
            background: #fbbf24;
          }

          &:nth-child(3) {
            background: #34d399;
          }
        }

        .chromeTitle {
          margin-left: 6px;
          font-size: 11px;
          color: rgba(255, 255, 255, 0.45);
          letter-spacing: 0.02em;
        }
      }

      .sitePreview {
        position: relative;
        flex: 1;
        min-height: min(52vh, 520px);
        background: #0a0e18;
      }

      .siteShot,
      .siteFrame {
        position: absolute;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .siteShot {
        z-index: 2;
        object-fit: cover;
        object-position: top center;
        background: #0a0e18;
      }

      .siteFrame {
        z-index: 1;
        background: #fff;

        &.isLive {
          z-index: 3;
        }
      }

      .siteLoading,
      .siteEmpty {
        position: absolute;
        inset: 0;
        z-index: 4;
        display: grid;
        place-items: center;
        margin: 0;
        padding: 20px;
        text-align: center;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.55);
        background: rgba(10, 14, 24, 0.92);
      }

      .siteLoading.hidden,
      .siteEmpty.hidden {
        display: none;
      }

      .siteNote {
        margin: 8px 0 0;
        padding: 0 4px;
        font-size: 11px;
        line-height: 1.4;
        color: rgba(255, 255, 255, 0.5);
        text-transform: none;
        letter-spacing: normal;
      }
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 520px) {
      .palette {
        .paletteGrid {
          grid-template-columns: 1fr;
        }
      }

      .preview .sitePreview,
      .preview .siteShot,
      .preview .siteFrame {
        min-height: 280px;
      }
    }
  }

  @media print {
    :global(body) {
      background: #ffffff !important;
      color: #111111 !important;
    }

    :global(a) {
      color: inherit !important;
      text-decoration: none !important;
    }

    .showcase {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      background: #ffffff !important;
      border-color: #d9d9d9 !important;
      color: #111111 !important;
      box-shadow: none !important;
    }

    .panel,
    .swatch {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .panel {
      background: #ffffff !important;
      border-color: #d9d9d9 !important;
    }

    .palette {
      .swatch {
        background: #ffffff !important;
        border-color: #d9d9d9 !important;

        .label,
        .value {
          color: #111111 !important;
        }

        .chip {
          border-color: #d9d9d9 !important;
          box-shadow: none !important;
        }
      }
    }

    .preview {
      .previewFrame,
      .previewChrome {
        border-color: #d9d9d9 !important;
      }

      .previewChrome {
        background: #f5f5f5 !important;
      }

      .sitePreview,
      .siteShot,
      .siteFrame {
        min-height: 320px !important;
      }
    }
  }
</style>
